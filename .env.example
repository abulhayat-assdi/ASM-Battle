# PostgreSQL connection string (VPS)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/team_battle?schema=public"

# Secret used to sign admin session JWTs. Use a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Initial super-admin created by the seed script
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Super Admin"
